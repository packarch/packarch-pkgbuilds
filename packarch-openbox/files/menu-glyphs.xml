<!DOCTYPE menu [
  <!ENTITY pipes "/usr/share/packarch/openbox/pipemenus">
]>
<openbox_menu xmlns="http://openbox.org/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://openbox.org/  file:///usr/share/openbox/menu.xsd">
  <menu id="root-menu" title="Menu" label="Openbox 3">
<!--	<separator label="Main Menu"/>  -->
		<item label=" Emulateur De Terminal">
			<action name="Execute">
				<command>alacritty</command>
			</action>
		</item>
		<item label=" Gestionnaire De Fichiers">
			<action name="Execute">
				<command>thunar</command>
			</action>
		</item>
		<item label=" Navigateur Internet">
			<action name="Execute">
				<command>firefox</command>
			</action>
		</item>
		<item label=" Editeur De Texte">
			<action name="Execute">
				<command>geany</command>
			</action>
		</item>
		<separator/>
		<menu id="app-menu" execute="obmenu-generator" label=" Applications"/>
		<menu id="apps-as-root" label=" Applications Root">
			<item label="Terminal (alacritty)">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root alacritty</execute>
				</action>
			</item>
			<item label="Gestionnaire De Fichiers (thunar)">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'dbus-run-session thunar'</execute>
				</action>
			</item>
			<item label="Editeur De Texte (geany)">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root geany</execute>
				</action>
			</item>
			<separator/>
			<item label="Gestionnaire De Fichiers CLI (ranger)">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'alacritty -e ranger'</execute>
				</action>
			</item>
			<item label="Editeur De Texte CLI (vim)">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'alacritty -e vim'</execute>
				</action>
			</item>
			<separator/>
			<item label="Lxappearance">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'lxappearance'</execute>
				</action>
			</item>
			<item label="QT5 Settings">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'qt5ct'</execute>
				</action>
			</item>
			<item label="kvantum Manager">
				<action name="Execute">
					<execute>~/.config/openbox/rofi/bin/apps_as_root 'kvantummanager'</execute>
				</action>
			</item>
		</menu>
		<menu id="quick-commands" label=" Commandes Rapides">
			<separator label="Commandes Rapides"/>
			<menu id="PacmanPipeMenu" execute="&pipes;/ac-pacman" label="Paquets"/>
			<menu id="FilesPipeMenu" execute="&pipes;/ac-files" label="Fichiers &amp; Dossiers"/>
			<menu id="SysdPipeMenu" execute="&pipes;/ac-systemd" label="Systemd &amp; Services"/>
		</menu>
		<menu id="ac-shots" execute="&pipes;/ac-shots" label=" Capture d'écran"/>
		<menu id="ac-record" execute="&pipes;/ac-record" label=" Vidéo d'écran"/>
		<separator/>
		<menu id="ac-places" execute="&pipes;/ac-places --recent ~/" label=" Parcourir"/>
		<menu id="ac-recent" execute="&pipes;/ac-recent-files" label=" Fichiers Récents"/>
		<menu id="preferences" label=" Preferences">
			<menu id="obconfig" label="Openbox">
				<menu id="ac-ob-menu" execute="&pipes;/ac-ob-menu" label="Style Du Menu"/>
				<item label="Config Openbox">
					<action name="Execute">
						<command>obconf</command>
					</action>
				</item>
				<separator/>
				<item label="Editer menu.xml">
					<action name="Execute">
						<command>exo-open ~/.config/openbox/menu-glyphs.xml</command>
					</action>
				</item>
				<item label="Editer rc.xml">
					<action name="Execute">
						<command>exo-open ~/.config/openbox/rc.xml</command>
					</action>
				</item>
				<item label="Editer autostart">
					<action name="Execute">
						<command>exo-open ~/.config/openbox/autostart</command>
					</action>
				</item>
				<separator/>
				<item label="Reconfigurer">
					<action name="Reconfigure"/>
				</item>
				<item label="Restart">
					<action name="Restart"/>
				</item>
			</menu>
			<menu id="CompositingPipeMenu" execute="&pipes;/ac-compositor" label="Compositeur"/>
			<menu id="XrandrPipeMenu" execute="&pipes;/ac-randr" label="Affichage / Moniteur"/>
			<separator/>
			<menu id="StylePipeMenu" execute="&pipes;/ac-change-style" label="Style Général"/>
			<menu id="FontPipeMenu" execute="&pipes;/ac-change-fonts" label="Style Des Fontes"/>
			<menu id="LauncherPipeMenu" execute="&pipes;/ac-change-launcher" label="Style Du Launcher"/>
			<menu id="PmenuPipeMenu" execute="&pipes;/ac-change-powermenu" label="Style Du Powermenu"/>
			<menu id="PolybarPipeMenu" execute="&pipes;/ac-change-polybar" label="Style De Polybar"/>
			<menu id="SchemePipeMenu" execute="&pipes;/ac-change-scheme" label="Style Du Terminal"/>
			<separator/>
			<menu id="CanvasPipeMenu" execute="&pipes;/ac-canvas" label="Générer Wallpaper"/>
			<item label="Réglages Wallpaper">
				<action name="Execute">
					<command>nitrogen</command>
				</action>
			</item>
			<item label="Réglages d'Apparence">
				<action name="Execute">
					<command>xfce4-appearance-settings</command>
				</action>
			</item>
			<item label="Réglages QT5">
				<action name="Execute">
					<command>qt5ct</command>
				</action>
			</item>
			<item label="Réglages Kvantum">
				<action name="Execute">
					<command>kvantummanager</command>
				</action>
			</item>
			<separator/>
			<item label="Réglages Energie">
				<action name="Execute">
					<command>xfce4-power-manager-settings</command>
				</action>
			</item>
			<item label="Réglages Audio">
				<action name="Execute">
					<command>pavucontrol</command>
				</action>
			</item>
			<item label="Réglages Xfce">
				<action name="Execute">
					<command>xfce4-settings-manager</command>
				</action>
			</item>
		</menu>
		<menu id="KeybindsPipeMenu" execute="&pipes;/ac-kb-pipemenu" label=" Raccourcis Clavier"/>
		<separator/>
		<item label=" Verrouiller l'Ecran">
			<action name="Execute">
				<command>betterlockscreen --lock</command>
			</action>
		</item>
		<menu id="Exit" label=" Systeme">
				<menu id="SystemPipeMenu" execute="&pipes;/ac-sysinfo" label=" Infos Système"/>
				<item label=" Déconnexion">
					<action name="Execute">
						<command>/usr/share/packarch/openbox/pipemenus/ac-powermenu --logout</command>
					</action>
				</item>
				<item label=" Suspendre">
					<action name="Execute">
						<command>/usr/share/packarch/openbox/pipemenus/ac-powermenu --suspent</command>
					</action>
				</item>
				<item label=" Redémarrer">
					<action name="Execute">
						<command>/usr/share/packarch/openbox/pipemenus/ac-powermenu --reboot</command>
					</action>
				</item>
				<item label=" Eteindre">
					<action name="Execute">
						<command>/usr/share/packarch/openbox/pipemenus/ac-powermenu --shutdown</command>
					</action>
				</item>
		</menu>
	</menu>
</openbox_menu>
