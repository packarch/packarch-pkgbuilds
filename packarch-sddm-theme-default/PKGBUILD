# Maintainer: Aditya Shakya <adi1090x@gmail.com>

pkgname=packarch-sddm-theme-default
pkgver=1.0
pkgrel=1
pkgdesc="Default sddm theme for Packarch"
url="https://github.com/packarch-os/extra-packages"
arch=('any')
license=('GPL3')
makedepends=()
depends=('sddm' 'qt5-declarative' 'qt5-graphicaleffects' 'qt5-quickcontrols2' 'qt5-svg')
conflicts=()
groups=(packarch-sddm-themes)
provides=("${pkgname}")
options=(!strip !emptydirs)

prepare() {
	cp -af ../files/. ${srcdir}
}

package() {
	(find packarch -type f -exec install -Dm 644 "{}" "$pkgdir/usr/share/sddm/themes/{}" \;)
}
