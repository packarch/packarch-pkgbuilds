# Maintainer: Fabrice Corraire <antidote1911@gmail.com>

pkgname=packarch-plymouth-theme
pkgver=1.0
pkgrel=1
pkgdesc="Default plymouth theme for Packarch"
url="https://github.com/packarch/packarch-packages"
arch=('any')
license=('GPL3')
makedepends=()
depends=('plymouth')
conflicts=()
groups=(packarch-plymouth-themes)
provides=("${pkgname}")
options=(!strip !emptydirs)

prepare() {
	cp -af ../files/. ${srcdir}
}

package() {
	(find packarch -type f -exec install -Dm 644 "{}" "$pkgdir/usr/share/plymouth/themes/{}" \;)
}
