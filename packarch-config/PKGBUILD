# Maintainer: Fabrice Corraire <antidote1911@gmail.com>

pkgname=packarch-config
pkgver=1.0
pkgrel=2
pkgdesc="Openbox WM Configurations for Packarch"
url="https://github.com/packarch/packarch-pkgbuild"
arch=('any')
license=('GPL3')
makedepends=()
depends=()
conflicts=()
provides=("${pkgname}")
options=(!strip !emptydirs)

prepare() {
	cp -af ../files/. ${srcdir}
}

package() {
	local _skeldir=${pkgdir}/etc/skel
	local _cachedir=${_skeldir}/.cache
	local _sharedir=${pkgdir}/usr/share/packarch/openbox
	local _obdir=${pkgdir}/etc/skel/.config/openbox
	local _configdir=${pkgdir}/etc/skel/.config

	mkdir -p "$_skeldir" && mkdir -p "$_cachedir" && mkdir -p "$_sharedir" && mkdir -p "$_obdir" && mkdir -p "$_configdir"
	
	# Copy cache files
	cp -r ${srcdir}/betterlockscreen 	"$_cachedir"
	install -Dm 644 rofi3.druncache		"$_cachedir"/rofi3.druncache
	
	cp -r ${srcdir}/.mpd 				"$_skeldir"
	cp -r ${srcdir}/.ncmpcpp 			"$_skeldir"
	cp -r ${srcdir}/.local	 			"$_skeldir"
	install -Dm 644 .dmrc				"$_skeldir"/.dmrc
	install -Dm 644 .face				"$_skeldir"/.face
	install -Dm 644 .gtkrc-2.0			"$_skeldir"/.gtkrc-2.0
	install -Dm 644 .hushlogin			"$_skeldir"/.hushlogin

	# Copy shared files & fix permissions
	cp -r ${srcdir}/icons 				"$_sharedir"
	cp -r ${srcdir}/menulib 			"$_sharedir"
	cp -r ${srcdir}/pipemenus 			"$_sharedir"
	chmod +x "$_sharedir"/pipemenus/*
	
	# Copy openbox specific configs
	cp -r ${srcdir}/alacritty 				"$_configdir"
	cp -r ${srcdir}/dconf 					"$_configdir"
	cp -r ${srcdir}/dunst 					"$_configdir"
	cp -r ${srcdir}/networkmanager-dmenu 	"$_configdir"
	cp -r ${srcdir}/nitrogen 				"$_configdir"
	cp -r ${srcdir}/obmenu-generator 		"$_configdir"
	cp -r ${srcdir}/Thunar 					"$_configdir"
	cp -r ${srcdir}/xfce4 					"$_configdir"
	cp -r ${srcdir}/zentile 				"$_configdir"
	cp -r ${srcdir}/geany 					"$_configdir"
	cp -r ${srcdir}/gtk-3.0 				"$_configdir"
	cp -r ${srcdir}/Kvantum 				"$_configdir"
	cp -r ${srcdir}/leafpad 				"$_configdir"
	cp -r ${srcdir}/libfm	 				"$_configdir"
	cp -r ${srcdir}/neofetch 				"$_configdir"
	cp -r ${srcdir}/polybar 				"$_configdir"
	cp -r ${srcdir}/pcmanfm 				"$_configdir"
	cp -r ${srcdir}/qt5ct 					"$_configdir"
	cp -r ${srcdir}/ranger 					"$_configdir"
	cp -r ${srcdir}/rofi 					"$_configdir"
	cp -r ${srcdir}/smplayer 				"$_configdir"
	install -Dm 644 mimeapps.list			"$_configdir"/mimeapps.list
	install -Dm 644 picom.conf				"$_configdir"/picom.conf

	# Copy window manager configs
	cp -r ${srcdir}/polybar_ob_dir		"$_obdir"/polybar
	cp -r ${srcdir}/rofi_ob_dir			"$_obdir"/rofi
	cp -r ${srcdir}/scripts 			"$_obdir"
	
	# Make scripts executable
	chmod +x "$_obdir"/scripts/*
	chmod +x "$_obdir"/rofi/bin/*
	chmod +x "$_skeldir"/.ncmpcpp/scripts/{album-art,ncmpcpp-art}
	chmod +x "$_configdir"/ranger/scope.sh
	
	# Polybar
	launch_files=(`find ${_configdir}/polybar -type f | grep launch.sh`)
	for _file in "${launch_files[@]}"; do
		chmod +x ${_file}
	done
	
	preview_files=(`find ${_configdir}/polybar -type f | grep preview.sh`)
	for _pfile in "${preview_files[@]}"; do
		chmod +x ${_pfile}
	done
	
	launch_files=(`find ${_obdir}/polybar -type f | grep launch.sh`)
	for _file in "${launch_files[@]}"; do
		chmod +x ${_file}
	done
	
	scripts_dir=(`find ${_configdir}/polybar -type d | grep scripts | grep -v rofi`)
	for _script in "${scripts_dir[@]}"; do
		chmod +x ${_script}/*
	done

	scripts_dir=(`find ${_obdir}/polybar -type d | grep scripts`)
	for _script in "${scripts_dir[@]}"; do
		chmod +x ${_script}/*
	done
	
	# Rofi
	rofi_dir=(`find ${_configdir}/rofi -type f | grep '.sh' | grep -v rasi`)
	for _rscript in "${rofi_dir[@]}"; do
		chmod +x ${_rscript}
	done

	install -Dm 755 autostart   		"$_obdir"/autostart
	install -Dm 644 rc.xml				"$_obdir"/rc.xml
	install -Dm 644 menu-glyphs.xml		"$_obdir"/menu-glyphs.xml
	install -Dm 644 menu-icons.xml		"$_obdir"/menu-icons.xml
	install -Dm 644 menu-minimal.xml	"$_obdir"/menu-minimal.xml
	install -Dm 644 menu-simple.xml		"$_obdir"/menu-simple.xml
}
